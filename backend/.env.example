# ─── CONFIGURAÇÃO DO GMAIL (RECOMENDADO) ───────────────────────
# 1. Ative a verificação em duas etapas na sua conta Google
# 2. Gere uma "Senha de app": https://myaccount.google.com/apppasswords
# 3. Use a senha de 16 dígitos gerada abaixo

SMTP_GMAIL_USER=seu_email@gmail.com
SMTP_GMAIL_PASS=sua_senha_de_app_16_digitos

# ─── CONFIGURAÇÃO SMTP INTERNO CTG (OPCIONAL) ──────────────────
# Deixe vazio para usar Gmail
SMTP_HOST=
SMTP_PORT=25
SMTP_FROM=ctg.engenharia@appmail.ctgbr.com.br
SMTP_USER=
SMTP_PASS=
SMTP_TLS=false

# ─── URLs E SEGURANÇA ──────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
JWT_SECRET=ctg-forecast-secret-local
DATABASE_URL=sua_string_de_conexao_postgres

# ─── ADMIN ─────────────────────────────────────────────────────
ADMIN_EMAIL=admin@ctgbr.com.br
ADMIN_PASS=senha_admin_segura
ADMIN_NAME=Administrador
